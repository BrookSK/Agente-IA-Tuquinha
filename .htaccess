RewriteEngine On

# Repassa o header Authorization para o PHP (necessário em Apache CGI/FastCGI)
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

RewriteCond %{REQUEST_URI} ^/guias/ [NC]
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
RewriteRule ^guias/(.*)$ public/guias/$1 [L]

# Se o arquivo ou diretório físico existir na raiz, entrega direto
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Caso contrário, encaminha tudo para o index.php da raiz
RewriteRule ^ index.php [L]
